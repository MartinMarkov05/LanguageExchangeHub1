
@model LanguageExchangeHub1.Services.Models.Index.IndexViewModel
@using Newtonsoft.Json

<html>
<head>
    <link rel="stylesheet" href="/wwwroot/css/site.css" />
</head>
<body>
    <main>

        <section>
   <header><h1 class="coursesHeadings">Your courses</h1></header>
            <div class="scrolMenu">

                @{

                    var indexViewModel = TempData["IndexViewModel"] as LanguageExchangeHub1.Services.Models.Index.IndexViewModel;
                    if (indexViewModel == null)
                    {
                        indexViewModel = Model;
                    }
                    var courseList = indexViewModel.Courses;

                    var filteredCourses = indexViewModel.FilteredCourses;
                    var languages = indexViewModel.Languages;
                    if (courseList != null)
                    {
                     
                        foreach (var item in courseList)
                        {
                            <div class="course">
                                <img />
                                <h2>@item.Name</h2>

                                @using (Html.BeginForm("CourseChat", "Course", FormMethod.Get, new { @class = "goToCourses" }))
                                {
                                    <button type="submit" value="@item.Id" name="courseId" placeholder="Go to course" class="goToCourses">Go to course</button>

                                }
                            </div>
                            <br />
                        }
                    }

                }
            </div>




        </section>

        <br />

        <section>
            <header><h1 class="coursesHeadings">Suggestesd courses</h1></header>
            <div class="course">
                <img />
                <h2>Name</h2>
                <button class="goToCourses">Go to course</button>
            </div>
            <br />
            <div class="course">
                <img />
                <h2>Name</h2>
                <button class="goToCourses">Go to course</button>
            </div>
        </section>

        <section id="searchCourseSection">
            <form method="post" asp-action="Search" asp-controller="Home">
                <input id="searchbar" type="text" name="courseName" placeholder="Search course..." />
                <button type="submit" onclick="showResults()">Search</button>
                @Html.DropDownList("LanguageId", new SelectList(indexViewModel.Languages, "Id", "Name"), "Select Language", new { @class = "form-control" })
                @{
                    var indexViewModelJson = JsonConvert.SerializeObject(indexViewModel);
                }
                <input type="hidden" name="indexViewModelJson" value="@indexViewModelJson" />


            </form>


            <div class="scrolMenu">

                <div class="courseCards">

                    @{if (filteredCourses != null)
                        {
                            foreach (var course in filteredCourses)
                            {
                                <div class="courseCard">
                                    <div class="header">@course.Name</div>
                                    <div class="CourseLanguage">
                                        @foreach (var language in languages)
                                        {
                                            if (language.Id == course.LanguageId)
                                            {
                                                <div>@language.Name</div>
                                            }
                                        }
                                    </div>
                                    <button type="submit" onclick="showCoursePreview('@course.Name',' @course.Description', '@course.ImageFile',' @course.Id') ">View</button>
                                </div>

                            }
                        }


                    }


                </div>
            </div>

            <div class="coursePreview" id="preview">
                
                    <div id="previewImage">
                        <img id="img" src="" alt="Course Image">
                    </div>
                    <div id="previewName"></div>
                    <div id="previewDescription"></div>
                    
                @using (Html.BeginForm("Request", "Course", FormMethod.Post ))
                {
                    <input type="text" id="previewId"  name="courseId" />

                   
                    <button type="submit" placeholder="Request To Join" class="RequestToJoin">Request to join</button>

                }
                <button type="button" onclick="closePreview()">&times;</button>

            </div>


        </section>
        @if (User.IsInRole("Admin"))
        {
            <a href="@Url.Action("CreateCourse", "Course")" class="btn btn-primary">Create Course</a>
        }


    </main>
</body>

</html>

<script>function showResults() {
        document.getElementsByClassName('scrolMenu').style.display = 'block';

    }
    var preview = document.getElementById('preview');

    function showCoursePreview(courseName, courseDescription, imageFile, courseId) {

        var courseNameElement = document.getElementById('previewName');
        var courseDescriptionElement = document.getElementById('previewDescription');
        var courseImageElement = document.getElementById('previewImage');
        var courseIdElement = document.getElementById('previewId');
        // Set the content of the preview div
        courseNameElement.innerHTML = courseName;
        courseDescriptionElement.innerHTML = courseDescription;
        courseIdElement.value = courseId;
        courseImageElement.querySelector('#img').src = imageFile;

        preview.classList.remove('close-preview');
        preview.classList.add('show-preview');

    }

    function closePreview() {
        var preview = document.getElementById('preview');

        preview.classList.add('close-preview');
    }</script>

<!-- Bootstrap JavaScript and dependencies -->
<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/popper.js@2.11.6/dist/umd/popper.min.js"></script>

<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>


